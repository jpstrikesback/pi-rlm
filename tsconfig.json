{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true
	},
	"include": ["index.ts", "src/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts"]
}
